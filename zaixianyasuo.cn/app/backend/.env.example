# ============================================================
# ImageCompressor 后端配置文件
# 复制此文件为 .env 并修改相应值
# cp .env.example .env
# ============================================================

# 数据库连接（留空使用 SQLite）
DATABASE_URL=

# JWT 密钥（启动时自动生成，也可手动设置）
SECRET_KEY=change_me

# 访问令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS 跨域设置
CORS_ORIGINS=*

# 图片压缩并发数
CONCURRENCY=4

# 单用户排队上限
MAX_QUEUE_PER_USER=20

# 全局排队上限（0=不限制）
MAX_QUEUE_GLOBAL=0

# 上传大小限制（MB）
MAX_UPLOAD_SIZE_MB=20
MAX_VIDEO_UPLOAD_SIZE_MB=200

# 视频时长限制（秒）
MAX_VIDEO_DURATION_SEC=600

# 视频压缩超时（秒）
VIDEO_COMPRESS_TIMEOUT_SEC=1800

# 前端 URL（邮件链接用）
FRONTEND_URL=http://127.0.0.1:8001

# 管理员邮箱（接收反馈通知）
ADMIN_EMAIL=admin@example.com

# 登录限制
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=30

# ============================================================
# 邮件配置（可选，不配置则邮件功能不可用）
# ============================================================
# 邮件提供商: smtp 或 sendgrid
EMAIL_PROVIDER=smtp

# SMTP 配置
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=1
SMTP_SSL=0

# SendGrid 配置
SENDGRID_API_KEY=
SENDGRID_FROM=

# ============================================================
# 管理员自动创建（首次启动时）
# ============================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_NICKNAME=管理员

# ============================================================
# 开发模式（跳过认证，本地调试用）
# ============================================================
AUTH_DISABLED=0
